# ╔══════════════════════════════════════════════════════════════════════╗
# ║  orkoprox — .env.example                                               ║
# ║                                                                        ║
# ║  Copy to .env and edit. orkoprox is OpenAI-API-compatible and ships    ║
# ║  with a single configured upstream provider; add your own providers    ║
# ║  via env. Privacy by default: no prompt logging, no phone-home.        ║
# ╚══════════════════════════════════════════════════════════════════════╝

# ── Server ─────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8091
LOG_LEVEL=INFO
LOG_JSON=true
ENVIRONMENT=development

# ── Auth ───────────────────────────────────────────────────────────────
# Comma-separated gateway keys, sent as X-API-Key or Authorization: Bearer.
# In production, keys shorter than 40 characters are rejected at boot.
PROXY_AUTH_REQUIRED=true
PROXY_API_KEYS=

# Namespace for gateway-emitted response headers (usage/quota/guard).
# Default produces e.g. "X-Orkoprox-Usage-Pct". Change for white-label setups.
BRAND_HEADER_PREFIX=X-Orkoprox

# ── Admin plane (strictly separate from the data plane) ────────────────
# Keys allowed to call /v1/admin/* (key management, tenant usage). These are
# NOT accepted on data-plane requests, and data-plane keys are NEVER accepted
# here — a leaked client key can never mint or revoke keys. Secure by default:
# if empty, the admin endpoints are DISABLED (403). Must not overlap with
# PROXY_API_KEYS. Comma-separated.
ADMIN_API_KEYS=

# ── Per-key request rate limiting (opt-in; 0 = disabled) ───────────────
# Token quotas cap total spend; these cap request rate + concurrency per key.
RATE_LIMIT_PER_MINUTE=0
RATE_LIMIT_BURST=0
RATE_LIMIT_CONCURRENCY=0

# ── Audit log (append-only JSONL; opt-in) ──────────────────────────────
# Records who/when/which-key-prefix/which-model/cost. NEVER the full key and
# NEVER prompt content (privacy by default).
AUDIT_LOG_ENABLED=false
AUDIT_LOG_PATH=/tmp/orkoprox-audit.jsonl

# ── Provider routing ───────────────────────────────────────────────────
# The default upstream is named "ovh". "stub" is a safety net that returns 503.
PRIMARY_PROVIDER=ovh
DEFAULT_PROVIDER=ovh
FALLBACK_PROVIDERS=ovh
FALLBACK_PROVIDERS_DEFAULT=ovh

# Optional: if set (comma-separated) and ENVIRONMENT=production, boot fails
# unless the primary provider is on this allowlist. Useful to pin a deployment
# to data-residency-compliant providers. Empty = no restriction.
PRODUCTION_ALLOWED_PROVIDERS=

# ── Primary provider (OpenAI-compatible upstream) ──────────────────────
# Set your provider's API key and the base URL of its OpenAI-compatible API.
OVH_API_KEY=YOUR_PROVIDER_API_KEY
OVH_BASE_URL=https://your-provider.example.com/v1

# ── Runtime hardening ──────────────────────────────────────────────────
REQUEST_TIMEOUT_SECONDS=120
PROVIDER_MAX_RETRIES=2
PROVIDER_RETRY_BACKOFF_SECONDS=0.5
PROVIDER_COOLDOWN_SECONDS=5
ADVERTISED_CONTEXT_WINDOW=131072
PROVIDER_CAPABILITY_OVERRIDES=
UPSTREAM_FORWARD_HEADERS=x-entitlements,x-quota-tier,x-org-id,x-user-id

# ── Observability ──────────────────────────────────────────────────────
METRICS_ENABLED=true

# ── Redis (per-key metering + health cache) — OPTIONAL ─────────────────
# orkoprox runs with NO Redis: per-key quotas/metering fall back to an
# in-process store (state resets on restart — fine for a single container).
# Set REDIS_URL for shared/persistent metering across processes or restarts.
# Use TLS for cross-host Redis — "rediss://" (two s) instead of "redis://".
# Example: REDIS_URL=rediss://:<password>@redis.internal:6380/0
REDIS_URL=

# ── Declarative policy file (TOML, optional, hot-reloadable) ───────────
# Point at an orkoprox.toml to set routing aliases + limits + quota defaults
# in one versionable file instead of many env vars. Empty = pure env config.
# Reload without restart: POST /v1/admin/policy/reload (admin plane).
# See orkoprox.example.toml for the schema.
POLICY_FILE=

# ═══════════════════════════════════════════════════════════════════════
# TIER ALIASES (quality-based routing)
# ═══════════════════════════════════════════════════════════════════════
# Clients send model="high" etc. → the gateway resolves it to provider/model.
#   xhigh   → large premium model
#   high    → default chat model
#   medium  → default chat model (same as high)
#   low     → small fast classifier model
MODEL_ALIAS_XHIGH=ovh/Meta-Llama-3_3-70B-Instruct
MODEL_ALIAS_HIGH=ovh/Mistral-Small-3.2-24B-Instruct-2506
MODEL_ALIAS_MEDIUM=ovh/Mistral-Small-3.2-24B-Instruct-2506
MODEL_ALIAS_LOW=ovh/Mistral-7B-Instruct-v0.3

# Finer reasoning tiers between "chat" and "reason"/"xhigh".
MODEL_ALIAS_REASON_LITE=ovh/gpt-oss-20b
MODEL_ALIAS_REASON_MID=ovh/Qwen3-32B
MODEL_ALIAS_LONG_CONTEXT=ovh/Qwen3.5-9B

# ═══════════════════════════════════════════════════════════════════════
# TASK ALIASES (task-based routing)
# ═══════════════════════════════════════════════════════════════════════
#   classify  → small/fast model
#   extract   → clean-JSON model
#   compose   → text-generation model
#   chat      → default chat model
#   reason    → reasoning model (cheaper than xhigh for long-prompt/short-output)
#   report    → large model for long coherent text
#   ocr       → multimodal model for receipts/documents
#   vision    → standard vision model
#   vision_x  → premium vision model (multi-page, diagrams)
#   image     → image generation
#   voice     → fast speech-to-text
#   voice_hq  → higher-quality speech-to-text
#   embed     → embedding model
MODEL_ALIAS_CLASSIFY=ovh/Mistral-7B-Instruct-v0.3
MODEL_ALIAS_EXTRACT=ovh/Mistral-Small-3.2-24B-Instruct-2506
MODEL_ALIAS_COMPOSE=ovh/Mistral-Small-3.2-24B-Instruct-2506
MODEL_ALIAS_CHAT=ovh/Mistral-Small-3.2-24B-Instruct-2506
MODEL_ALIAS_REASON=ovh/gpt-oss-120b
MODEL_ALIAS_REPORT=ovh/Meta-Llama-3_3-70B-Instruct
MODEL_ALIAS_OCR=ovh/Mistral-Small-3.2-24B-Instruct-2506
MODEL_ALIAS_VISION=ovh/Mistral-Small-3.2-24B-Instruct-2506
MODEL_ALIAS_VISION_X=ovh/Qwen2.5-VL-72B-Instruct
MODEL_ALIAS_IMAGE=ovh/stable-diffusion-xl-base-v10
MODEL_ALIAS_VOICE=ovh/whisper-large-v3-turbo
MODEL_ALIAS_VOICE_HQ=ovh/whisper-large-v3
MODEL_ALIAS_EMBED=ovh/bge-multilingual-gemma2

# ═══════════════════════════════════════════════════════════════════════
# CONTENT GUARD (pre/post moderation filter)
# ═══════════════════════════════════════════════════════════════════════
GUARD_ENABLED=true
GUARD_PRE_MODEL=ovh/Qwen3Guard-Gen-0.6B
GUARD_POST_MODEL=ovh/Qwen3Guard-Gen-8B
# Comma-separated API keys allowed to skip the guard (internal service tools).
GUARD_BYPASS_KEYS=

# ═══════════════════════════════════════════════════════════════════════
# ALERTING (optional)
# ═══════════════════════════════════════════════════════════════════════
ALERT_TELEGRAM_BOT_TOKEN=
ALERT_TELEGRAM_CHAT_ID=
ALERT_BACKEND_DOWN_CONSECUTIVE_FAILS=2
ALERT_P95_LATENCY_THRESHOLD_MS=30000
ALERT_FALLBACK_RATE_THRESHOLD=0.2
ALERT_THROTTLE_SECONDS=1800

# ═══════════════════════════════════════════════════════════════════════
# RERANKER SIDECAR (cross-encoder reranking, POST /v1/rerank)
# ═══════════════════════════════════════════════════════════════════════
# Optional self-hosted TEI sidecar (bge-reranker-v2-m3). The chat providers
# do not offer a rerank endpoint. See the `reranker` service in docker-compose.
RERANKER_ENABLED=true
RERANKER_BASE_URL=http://reranker:80
RERANKER_MODEL=bge-reranker-v2-m3
RERANKER_TIMEOUT_S=30
# HuggingFace model id for the TEI sidecar.
RERANKER_MODEL_ID=BAAI/bge-reranker-v2-m3
